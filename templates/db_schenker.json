{
  "name": "DB Schenker — PTT",
  "description": "Application for permit to transfer containerized cargo — DB Schenker, Carson CA",
  "filename_prefix": "PTT_DBSchenker",
  "html_template": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n@page { size: letter; margin: 14mm 16mm 12mm 16mm; }\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial, Helvetica, sans-serif; font-size: 9.5pt; color: #1a1a1a; line-height: 1.4; }\n.page { width: 100%; }\n\n/* Header */\n.header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }\n.header-left { font-size: 8.5pt; color: #333; line-height: 1.6; }\n.header-right { text-align: right; }\n.logo-box { display: flex; align-items: center; gap: 6px; justify-content: flex-end; margin-bottom: 6px; }\n.logo-db { background: #e30613; color: white; font-size: 16pt; font-weight: 900; padding: 3px 8px; border-radius: 2px; line-height: 1.1; }\n.logo-schenker { font-size: 13pt; font-weight: 700; color: #1a1a1a; letter-spacing: -0.5px; }\n.logo-tagline { font-size: 7pt; color: #e30613; font-weight: 600; text-align: right; margin-bottom: 6px; }\n.header-address { font-size: 8pt; color: #333; text-align: right; line-height: 1.5; }\n.header-links { font-size: 7.5pt; color: #0066cc; text-align: right; }\n\n/* Date + Firms row */\n.date-firms { display: flex; justify-content: flex-end; align-items: center; gap: 18px; margin-bottom: 8px; }\n.date-block { font-size: 9pt; }\n.date-block span { font-size: 15pt; font-weight: 700; border: 2px solid #cc0000; padding: 2px 10px; display: inline-block; }\n.firms-block { font-size: 9pt; }\n.firms-block span { font-weight: 700; border: 2px solid #cc0000; padding: 2px 8px; display: inline-block; }\n\n/* Re: line */\n.re-line { font-weight: 700; font-size: 10pt; margin-bottom: 8px; border-bottom: 1px solid #000; padding-bottom: 4px; }\n\n/* Body paragraph */\n.body-para { font-size: 9pt; margin-bottom: 12px; text-align: justify; }\n\n/* Fields table */\n.fields-table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }\n.fields-table td { padding: 4px 2px; vertical-align: bottom; font-size: 9pt; }\n.field-label { font-weight: 700; white-space: nowrap; padding-right: 6px; }\n.field-line { border-bottom: 1px solid #333; min-width: 60px; display: inline-block; }\n.field-value { font-size: 13pt; font-weight: 700; border: 2px solid #cc0000; padding: 1px 8px; display: inline-block; min-width: 60px; text-align: center; }\n.field-sub { font-size: 7.5pt; color: #555; display: block; text-align: center; margin-top: 1px; }\n.field-value-lg { font-size: 15pt; font-weight: 700; border: 2px solid #cc0000; padding: 2px 12px; display: inline-block; }\n\n/* Signature section */\n.sig-section { margin-top: 10px; }\n.we-concur { text-align: center; font-weight: 700; font-size: 10pt; margin-bottom: 4px; }\n.sig-row { display: flex; justify-content: space-between; gap: 20px; margin-bottom: 2px; }\n.sig-block { flex: 1; border-bottom: 1px solid #333; }\n.sig-label { font-size: 7.5pt; color: #444; margin-top: 2px; }\n.approved-row { margin-top: 6px; }\n.approved-row span { font-weight: 700; margin-right: 8px; }\n.approved-line { display: inline-block; border-bottom: 1px solid #333; width: 200px; }\n\n/* Divider */\n.stars { text-align: center; font-size: 8pt; letter-spacing: 1px; color: #333; margin: 10px 0; }\n\n/* Transfer Record */\n.transfer-title { text-align: center; font-size: 14pt; font-weight: 900; font-family: 'Times New Roman', serif; margin: 6px 0 10px; }\n.delivered-row { margin-bottom: 6px; font-size: 9.5pt; }\n.delivered-name { font-size: 15pt; font-weight: 900; display: inline-block; border-bottom: 2px solid #333; padding: 0 6px; margin: 0 6px; }\n.cartman-label { font-size: 8pt; color: #444; display: block; text-align: center; margin-left: 80px; }\n.sig-row-transfer { display: flex; justify-content: flex-end; margin: 14px 0 4px; }\n.sig-block-right { width: 260px; border-bottom: 1px solid #333; }\n.sig-label-right { font-size: 7.5pt; color: #444; text-align: center; margin-top: 2px; }\n\n/* Received section */\n.received-row { font-size: 9.5pt; margin-top: 8px; }\n.received-name { font-size: 14pt; font-weight: 900; text-decoration: underline; margin: 0 6px; }\n.final-sigs { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 14px; }\n.final-date { font-size: 9.5pt; font-weight: 700; }\n.final-date-line { border-bottom: 1px solid #333; display: inline-block; width: 120px; }\n.final-sig-block { text-align: center; }\n.final-sig-line { border-bottom: 1px solid #333; width: 160px; display: inline-block; }\n.final-sig-label { font-size: 7.5pt; color: #444; margin-top: 2px; }\n.dsv-internal { text-align: center; font-size: 8pt; color: #666; margin-top: 14px; }\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <!-- HEADER -->\n  <div class=\"header\">\n    <div class=\"header-left\">\n      Director, Airport Operations<br>\n      U.S Customs and Border Protection<br>\n      11099 S. La Cienega Blvd<br>\n      Los Angeles, CA 90045\n    </div>\n    <div class=\"header-right\">\n      <div class=\"logo-box\">\n        <div class=\"logo-db\">DB</div>\n        <div class=\"logo-schenker\">SCHENKER</div>\n      </div>\n      <div class=\"logo-tagline\">150 Years Elevating Lives</div>\n      <div class=\"header-address\">990 E. 233 St.<br>Carson, CA. 90745</div>\n      <div class=\"header-links\">www.dbschenker.com<br>www.nowthatslogistics.com</div>\n    </div>\n  </div>\n\n  <!-- DATE + FIRMS -->\n  <div class=\"date-firms\">\n    <div class=\"date-block\">Date: &nbsp;<span>{{ fecha }}</span></div>\n    <div class=\"firms-block\">Confirm Firms code &nbsp;<span>{{ firms }}</span></div>\n  </div>\n\n  <!-- RE LINE -->\n  <div class=\"re-line\">Re: &nbsp; Application for permit to transfer containerized cargo</div>\n\n  <!-- BODY -->\n  <div class=\"body-para\">\n    Application is made to transfer the Containers or Consolidations listed below from the airline&rsquo;s premises to DB\n    Schenker Services Container Station at Los Angeles International Airport. An abstract of the aircraft manifest\n    showing the cargo referred to is attached to this application.\n  </div>\n\n  <!-- IMPORTING CARRIER -->\n  <table class=\"fields-table\">\n    <tr>\n      <td class=\"field-label\" style=\"width:130px\">Importing Carrier:</td>\n      <td style=\"width:110px\">\n        <div class=\"field-value\">{{ iata }}</div>\n        <span class=\"field-sub\">Name</span>\n      </td>\n      <td style=\"width:110px\">\n        <div class=\"field-value\">{{ flight }}</div>\n        <span class=\"field-sub\">Flight</span>\n      </td>\n      <td>\n        <span class=\"field-line\" style=\"min-width:120px\">&nbsp;{{ aircraft_no }}&nbsp;</span>\n        <span class=\"field-sub\" style=\"text-align:left;margin-left:0\">Aircraft NO</span>\n      </td>\n    </tr>\n  </table>\n\n  <!-- ARRIVAL DATE + TACM -->\n  <table class=\"fields-table\">\n    <tr>\n      <td class=\"field-label\" style=\"width:130px\">Arrival Date:</td>\n      <td style=\"width:160px\">\n        <span class=\"field-line\" style=\"min-width:120px\">&nbsp;{{ arrival_date }}&nbsp;</span>\n      </td>\n      <td class=\"field-label\" style=\"width:200px\">LAX manifest or port TACM NO.</td>\n      <td>\n        <span class=\"field-line\" style=\"min-width:120px\">&nbsp;{{ tacm }}&nbsp;</span>\n      </td>\n    </tr>\n  </table>\n\n  <!-- MAWB -->\n  <table class=\"fields-table\">\n    <tr>\n      <td class=\"field-label\" style=\"width:130px\">Master Air Waybill NO.</td>\n      <td colspan=\"3\">\n        <div class=\"field-value-lg\">{{ mawb_full }}</div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- HAWB COUNT -->\n  <table class=\"fields-table\">\n    <tr>\n      <td class=\"field-label\" style=\"width:280px\">Total Number of House Air Waybills</td>\n      <td><span class=\"field-line\" style=\"min-width:200px\">&nbsp;{{ hawb_count }}&nbsp;</span></td>\n    </tr>\n  </table>\n\n  <!-- PACKAGES + WEIGHT -->\n  <table class=\"fields-table\">\n    <tr>\n      <td class=\"field-label\" style=\"width:280px\">Total Number Units and/or Packages</td>\n      <td style=\"width:100px\">\n        <div class=\"field-value\">{{ packages }}</div>\n      </td>\n      <td class=\"field-label\" style=\"padding-left:16px;width:100px\">Total Weight</td>\n      <td>\n        <div class=\"field-value\">{{ weight }}</div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- SIGNATURES -->\n  <div class=\"sig-section\">\n    <div class=\"we-concur\">We Concur</div>\n    <div class=\"sig-row\">\n      <div>\n        <div class=\"sig-block\" style=\"width:260px\">&nbsp;</div>\n        <div class=\"sig-label\">Signature of authorized agent of container station</div>\n      </div>\n      <div>\n        <div class=\"sig-block\" style=\"width:260px\">&nbsp;</div>\n        <div class=\"sig-label\">Signature of agent or Importing carrier</div>\n      </div>\n    </div>\n    <div class=\"approved-row\">\n      <span>Approved</span>\n      <span class=\"approved-line\">&nbsp;</span>\n    </div>\n  </div>\n\n  <!-- DIVIDER -->\n  <div class=\"stars\">*************************************************************************************</div>\n\n  <!-- TRANSFER RECORD -->\n  <div class=\"transfer-title\">Transfer Record</div>\n\n  <div class=\"delivered-row\">\n    Delivered to: <span class=\"delivered-name\">DB SCHENKER</span> &nbsp; in apparent good order and condition except as noted: &nbsp; TFS\n    <span class=\"cartman-label\">Cartman, C.H.L. No/or container trucker</span>\n  </div>\n\n  <div class=\"sig-row-transfer\">\n    <div>\n      <div class=\"sig-block-right\">&nbsp;</div>\n      <div class=\"sig-label-right\">Signature of cartman or trucker</div>\n    </div>\n  </div>\n\n  <!-- DIVIDER -->\n  <div class=\"stars\">*************************************************************************************</div>\n\n  <!-- RECEIVED -->\n  <div class=\"received-row\">\n    Received at <span class=\"received-name\">DB SCHENKER</span> Container Station\n  </div>\n\n  <!-- FINAL SIGS -->\n  <div class=\"final-sigs\">\n    <div>\n      <span class=\"final-date\">Date: &nbsp;</span>\n      <span class=\"final-date-line\">&nbsp;</span>\n    </div>\n    <div class=\"final-sig-block\">\n      <div class=\"final-sig-line\">&nbsp;</div>\n      <div class=\"final-sig-label\">Signature of container customs Inspector</div>\n    </div>\n    <div class=\"final-sig-block\">\n      <div class=\"final-sig-line\">&nbsp;</div>\n      <div class=\"final-sig-label\">Signature of agent at container station</div>\n    </div>\n  </div>\n\n  <div class=\"dsv-internal\">DSV internal</div>\n\n</div>\n</body>\n</html>"
}
